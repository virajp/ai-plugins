#!/usr/bin/env bash
#MISE description="Static validation of the vwf plugin tree (manifests, deps, asset refs, agent names)"
#MISE dir="{{ config_root }}"

# Deterministic invariants for the vwf plugin:
#  1. vwf plugin.json and the shared marketplace.json are valid JSON.
#  2. vwf's dependency list is identical in plugin.json and its marketplace entry.
#  3. Every ${CLAUDE_PLUGIN_ROOT}/... reference in vwf docs resolves to a real file.
#  4. Each agent's `name:` frontmatter matches its filename.

set -euo pipefail
source "${MISE_PROJECT_ROOT}/.config/mise/tasks/_scripts/_helpers"

cd "$MISE_PROJECT_ROOT"

command -v python3 >/dev/null 2>&1 || { print_error "python3 is required for vwf:check"; exit 1; }

VWF="plugins/vwf"
PLUGIN_JSON="$VWF/.claude-plugin/plugin.json"
MARKETPLACE_JSON=".claude-plugin/marketplace.json"
fail=0

print_header "1. Validating manifests are well-formed JSON ..."
for f in "$PLUGIN_JSON" "$MARKETPLACE_JSON"; do
  if python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$f" 2>/dev/null; then
    print_yellow "  ok   $f"
  else
    print_error "  FAIL invalid JSON: $f"
    fail=1
  fi
done

print_header "2. Checking vwf dependency lists are in sync ..."
if [[ "$fail" -eq 0 ]]; then
  if python3 - "$PLUGIN_JSON" "$MARKETPLACE_JSON" <<'PY'
import json, sys

plugin_path, market_path = sys.argv[1], sys.argv[2]
norm = lambda deps: sorted((d.get("marketplace"), d.get("name")) for d in deps or [])

plugin_deps = norm(json.load(open(plugin_path)).get("dependencies"))
entry = next((p for p in json.load(open(market_path)).get("plugins", []) if p.get("name") == "vwf"), None)
if entry is None:
    print("  no vwf entry in marketplace.json")
    sys.exit(1)
market_deps = norm(entry.get("dependencies"))

if plugin_deps != market_deps:
    print(f"  plugin.json:    {plugin_deps}")
    print(f"  marketplace:    {market_deps}")
    sys.exit(1)
PY
  then
    print_yellow "  ok   dependency lists match"
  else
    print_error "  FAIL dependency lists differ between plugin.json and marketplace.json"
    fail=1
  fi
else
  print_warn "  skipped (manifests did not parse)"
fi

print_header "3. Checking \${CLAUDE_PLUGIN_ROOT} asset references resolve ..."
refs=$(grep -rhoE '\$\{CLAUDE_PLUGIN_ROOT\}/[A-Za-z0-9_./-]+' "$VWF" | sort -u || true)
if [[ -z "$refs" ]]; then
  print_warn "  none found"
else
  while IFS= read -r ref; do
    rel="${ref#\$\{CLAUDE_PLUGIN_ROOT\}/}"
    if [[ -f "$VWF/$rel" ]]; then
      print_yellow "  ok   $rel"
    else
      print_error "  FAIL missing: $VWF/$rel  (referenced as $ref)"
      fail=1
    fi
  done <<< "$refs"
fi

print_header "4. Checking agent name: frontmatter matches filename ..."
for f in "$VWF"/agents/*.md; do
  base="$(basename "$f" .md)"
  name="$(awk -F': *' '/^name:/{print $2; exit}' "$f")"
  if [[ "$name" == "$base" ]]; then
    print_yellow "  ok   $base"
  else
    print_error "  FAIL $f declares name: '$name' (expected '$base')"
    fail=1
  fi
done

if [[ "$fail" -ne 0 ]]; then
  print_error "vwf:check failed"
  exit 1
fi

print_header "All vwf checks passed!"
