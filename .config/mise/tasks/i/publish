#!/usr/bin/env bash
#MISE description="Publish the installer to npmjs.org"
#MISE dir="{{ config_root }}"

#USAGE flag "--dry-run" help="run all checks and packaging without publishing"

set -e
source "${MISE_PROJECT_ROOT}/.config/mise/tasks/_scripts/_helpers"

cd "$MISE_PROJECT_ROOT"

# Local publish path (CI publishes via OIDC in .github/workflows/release.yml).
# Publishing goes through the npm CLI; pnpm drives the gates below and everything
# else. Prefer releasing via CI (`mise run i:release` + push the tag) so every
# version keeps the strongest npm trust level.
print_header "Verifying npm authentication ..."
if ! npm whoami >/dev/null 2>&1; then
  print_error "Not logged in to npm. Run \`npm login\` first, then retry."
  exit 1
fi

# Gate publishing on the smoke tests and package verification (both via pnpm).
mise run i:test
mise run i:build

VERSION="$(node -p "require('./package.json').version")"

if [[ "${usage_dry_run:-false}" == "true" ]]; then
  print_header "Dry-run publish of @askviraj/ai-plugins@${VERSION} ..."
  npm publish --access public --dry-run
  print_header "Dry run complete — nothing was published."
  exit 0
fi

print_header "Publishing @askviraj/ai-plugins@${VERSION} to npmjs.org ..."
npm publish --access public
print_header "Published @askviraj/ai-plugins@${VERSION}!"
