#!/usr/bin/env bash

#MISE description="Setup AI plugins"
#MISE hide=true

set -e
source "${MISE_PROJECT_ROOT}/.config/mise/tasks/_scripts/_helpers"

if ! command -v claude &> /dev/null; then
  echo "Claude CLI not found. Please run \`mise run setup:all\` to install it first."
  exit 1
fi

function updatePlugin() {
  local plugin_name="$1"
  local plugin_marketplace="$2"
  local scope="$3"
  local full_plugin_name="$plugin_name@$plugin_marketplace"

  local installed_scope
  installed_scope=$(claude plugin list --json | jq -r --arg id "$full_plugin_name" '.[] | select(.id == $id) | .scope')
  plugin_enabled=$(claude plugin list --json | jq -r --arg id "$full_plugin_name" '.[] | select(.id == $id) | .enabled')

  if [[ -n "$installed_scope" ]]; then
    print_header "Updating $full_plugin_name (scope: $installed_scope)..."
    claude plugin update --scope "$installed_scope" "$full_plugin_name"
  else
    print_header "Installing $full_plugin_name (scope: $scope)..."
    claude plugin install --scope "$scope" "$full_plugin_name"
  fi
  if [[ "$plugin_enabled" != "true" ]]; then
    claude plugin enable --scope "$scope" "$full_plugin_name"
  fi
}

print_header "Adding marketplace to Claude..."
claude plugin marketplace add virajp/claude-plugins || true
claude plugin marketplace update virajp-plugins || true
claude plugin marketplace add MemPalace/mempalace || true
claude plugin marketplace update mempalace || true
claude plugin marketplace update claude-plugins-official || true

print_header "Setting up AI plugins ..."
updatePlugin context7 claude-plugins-official user
updatePlugin superpowers claude-plugins-official user
updatePlugin frontend-design claude-plugins-official user
updatePlugin mempalace mempalace user
updatePlugin skills virajp-plugins user

updatePlugin typescript-lsp virajp-plugins user

# Install graphify skill
print_header "Installing Graphify skill for Claude..."
graphify install --platform claude
print_header "Installing Graphify skill for OpenCode..."
graphify install --platform opencode

# Install graphify post-commit hook
print_header "Installing Graphify post-commit hook..."
graphify hook install

# OpenCode setup
opencode plugin --global "@devtheops/opencode-plugin-mempalace"
