#!/usr/bin/env bash
#MISE description="Upgrade dependencies"
#MISE hide=true

set -e
source "${MISE_PROJECT_ROOT}/.config/mise/tasks/_scripts/_helpers"

print_header "Update pnpm ..."
pnpm self-update latest-11

print_header "Install node modules ..."
pnpm install --aggregate-output --child-concurrency 10 --network-concurrency 10 --recursive
