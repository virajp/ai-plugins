#!/usr/bin/env bash
#MISE description="Static validation of every plugin (manifests, deps, asset refs, agent names, marketplace sync)"
#MISE dir="{{ config_root }}"

# Deterministic invariants across all local plugins under plugins/*:
#  - plugin.json is valid JSON and its "name" matches the directory name.
#  - the plugin is registered in marketplace.json with source ./plugins/<name>.
#  - dependency lists are identical in plugin.json and the marketplace entry.
#  - every ${CLAUDE_PLUGIN_ROOT}/... reference resolves to a real path (file or dir).
#  - each agent's `name:` frontmatter matches its filename (plugins with agents/).
#  - each skill has frontmatter with a `name:` (matching its dir), a
#    `description:`, and — when present — a plausible `model:`.
#  - skill names are unique across all local plugins (OpenCode installs them
#    into one flat namespace).
#  - each hooks.json is valid JSON and every ${CLAUDE_PLUGIN_ROOT} script it names
#    resolves to an executable file.
#  - relative ./ or ../ .md links under any plugin's assets/examples/ resolve.
#  - every ./plugins-sourced marketplace entry has a matching local directory.
#  - the bin/claude.mjs PLUGINS allowlist equals the marketplace plugin set,
#    PROJECT_SCOPED / OPT_IN are subsets of it, and PLUGIN_DEPS mirrors the
#    marketplace dependency lists (the OpenCode target expands deps from it).
# url-sourced marketplace entries (e.g. mempalace) are not authored here, so only
# their JSON validity is covered. Skill/plugin version numbers are intentionally
# not cross-checked — they are independent by design.

set -euo pipefail
source "${MISE_PROJECT_ROOT}/.config/mise/tasks/_scripts/_helpers"

cd "$MISE_PROJECT_ROOT"

command -v python3 >/dev/null 2>&1 || { print_error "python3 is required for plugins:check"; exit 1; }

python3 - <<'PY'
import glob, json, os, re, subprocess, sys

GREEN, YELLOW, RED, BOLD, OFF = "\033[0;32m", "\033[0;33m", "\033[0;31m", "\033[1m", "\033[0m"
def header(m): print(f"{GREEN}{BOLD}{m}{OFF}")
def ok(m):     print(f"{YELLOW}  ok   {m}{OFF}")
def bad(m):    print(f"{RED}{BOLD}  FAIL {m}{OFF}")

MARKET = ".claude-plugin/marketplace.json"
REF_RE = re.compile(r"\$\{CLAUDE_PLUGIN_ROOT\}/([A-Za-z0-9_./-]+)")
# Plausible skill `model:` values: the short aliases the repo uses plus any
# claude-* model id — kept permissive on purpose (a bare non-empty alias passes).
MODEL_RE = re.compile(r"^(sonnet|opus|haiku|inherit|claude[\w.\[\]-]+)$", re.I)
# Relative markdown link target (./ or ../), stripping any #anchor.
LINK_RE = re.compile(r"\]\((\.{1,2}/[^)\s#]+\.md)(?:#[^)\s]*)?\)")
failed = False

KEY_RE = re.compile(r"^([A-Za-z0-9_-]+):\s*(.*?)\s*$")

def frontmatter(path):
    """Parse leading YAML frontmatter into a flat {key: value} of top-level scalar
    keys. An empty-valued or block/folded (|, >) key absorbs its indented
    continuation lines as the value. Returns None when the file has no
    `---`-fenced frontmatter block."""
    text = open(path, encoding="utf-8").read()
    m = re.match(r"^---\s*\n(.*?)\n---\s*(?:\n|$)", text, re.S)
    if not m:
        return None
    lines = m.group(1).splitlines()
    fm = {}
    i = 0
    while i < len(lines):
        km = KEY_RE.match(lines[i])
        if not km:
            i += 1
            continue
        key, val = km.group(1), km.group(2).strip().strip("'\"")
        i += 1
        if val in ("", "|", ">", "|-", ">-", "|+", ">+"):
            block = []
            while i < len(lines) and (lines[i].strip() == "" or lines[i][:1] in (" ", "\t")):
                block.append(lines[i].strip())
                i += 1
            joined = " ".join(b for b in block if b).strip()
            if joined:
                val = joined
        fm[key] = val
    return fm

def hook_commands(obj):
    """Every string `command` value anywhere in a hooks.json structure."""
    out = []
    if isinstance(obj, dict):
        for k, v in obj.items():
            if k == "command" and isinstance(v, str):
                out.append(v)
            else:
                out.extend(hook_commands(v))
    elif isinstance(obj, list):
        for it in obj:
            out.extend(hook_commands(it))
    return out

header("Validating marketplace.json ...")
try:
    market = json.load(open(MARKET))
    ok(MARKET)
except Exception as e:
    bad(f"{MARKET} is not valid JSON: {e}")
    sys.exit(1)

entries = {p.get("name"): p for p in market.get("plugins", [])}
norm = lambda deps: sorted((d.get("marketplace"), d.get("name")) for d in deps or [])

def asset_refs(plugin_dir):
    """All distinct ${CLAUDE_PLUGIN_ROOT}/... reference paths under a plugin dir."""
    found = set()
    for base, _, files in os.walk(plugin_dir):
        for fn in files:
            path = os.path.join(base, fn)
            try:
                text = open(path, encoding="utf-8").read()
            except (UnicodeDecodeError, OSError):
                continue  # skip binaries / unreadable
            found.update(REF_RE.findall(text))
    return sorted(found)

header("Checking local plugins ...")
skill_names = {}  # skill name -> [SKILL.md paths] across all local plugins
plugin_dirs = sorted(glob.glob("plugins/*/"))
if not plugin_dirs:
    bad("no plugins found under plugins/")
    failed = True

for pdir in plugin_dirs:
    name_dir = pdir.rstrip("/").split("/")[-1]
    errs = []

    # 1. plugin.json valid + name matches dir
    pj_path = os.path.join(pdir, ".claude-plugin", "plugin.json")
    pj = None
    if not os.path.isfile(pj_path):
        errs.append(f"missing {pj_path}")
    else:
        try:
            pj = json.load(open(pj_path))
        except Exception as e:
            errs.append(f"invalid JSON in {pj_path}: {e}")
    if pj is not None and pj.get("name") != name_dir:
        errs.append(f"plugin.json name '{pj.get('name')}' != dir '{name_dir}'")

    # 2. registered in marketplace with the right local source
    entry = entries.get(name_dir)
    if entry is None:
        errs.append(f"not registered in {MARKET}")
    elif entry.get("source") != f"./{pdir.rstrip('/')}":
        errs.append(f"marketplace source '{entry.get('source')}' != './{pdir.rstrip('/')}'")

    # 3. dependency lists in sync
    if pj is not None and entry is not None:
        if norm(pj.get("dependencies")) != norm(entry.get("dependencies")):
            errs.append(f"deps differ: plugin.json={norm(pj.get('dependencies'))} marketplace={norm(entry.get('dependencies'))}")

    # 4. asset refs resolve (file or directory — templates are copied as trees)
    refs = asset_refs(pdir)
    for rel in refs:
        if not os.path.exists(os.path.join(pdir, rel)):
            errs.append(f"unresolved asset ref ${{CLAUDE_PLUGIN_ROOT}}/{rel}")

    # 5. agent name <-> filename
    agent_files = sorted(glob.glob(os.path.join(pdir, "agents", "*.md")))
    for af in agent_files:
        m = re.search(r"(?m)^name:\s*(.+?)\s*$", open(af, encoding="utf-8").read())
        declared = m.group(1) if m else None
        expected = os.path.basename(af)[:-3]
        if declared != expected:
            errs.append(f"agent {af} declares name '{declared}' (expected '{expected}')")

    # 6. skill frontmatter: name (matches its dir) + description + plausible
    #    model when one is pinned; collect names for the uniqueness check below
    skill_files = sorted(glob.glob(os.path.join(pdir, "skills", "*", "SKILL.md")))
    for sf in skill_files:
        fm = frontmatter(sf)
        if fm is None:
            errs.append(f"skill {sf} has no YAML frontmatter")
            continue
        expected = os.path.basename(os.path.dirname(sf))
        if fm.get("name") != expected:
            errs.append(f"skill {sf} declares name '{fm.get('name')}' (expected '{expected}')")
        if not fm.get("description"):
            errs.append(f"skill {sf} missing description")
        if "model" in fm and not MODEL_RE.match(fm["model"] or ""):
            errs.append(f"skill {sf} has implausible model '{fm['model']}'")
        skill_names.setdefault(expected, []).append(sf)

    # 7. hooks.json valid + every ${CLAUDE_PLUGIN_ROOT} script exists & is executable
    hooks_path = os.path.join(pdir, "hooks", "hooks.json")
    if os.path.isfile(hooks_path):
        try:
            hooks = json.load(open(hooks_path))
        except Exception as e:
            errs.append(f"invalid JSON in {hooks_path}: {e}")
        else:
            for cmd in hook_commands(hooks):
                token = cmd.split()[0] if cmd.split() else ""
                if "${CLAUDE_PLUGIN_ROOT}" not in token:
                    continue  # bare PATH command (e.g. `rtk hook claude`)
                rel = token.replace("${CLAUDE_PLUGIN_ROOT}/", "").replace("${CLAUDE_PLUGIN_ROOT}", "")
                sp = os.path.join(pdir, rel)
                if not os.path.isfile(sp):
                    errs.append(f"hook script {token} does not resolve to a file")
                elif not os.access(sp, os.X_OK):
                    errs.append(f"hook script {token} is not executable")

    if errs:
        failed = True
        bad(name_dir)
        for e in errs:
            print(f"{RED}         - {e}{OFF}")
    else:
        ok(f"{name_dir} — manifest, name, registered, deps, refs({len(refs)}), "
           f"agents({len(agent_files)}), skills({len(skill_files)})")

header("Checking skill names are unique across plugins ...")
dupes = {n: ps for n, ps in skill_names.items() if len(ps) > 1}
if dupes:
    failed = True
    for n, ps in sorted(dupes.items()):
        bad(f"skill name '{n}' declared by multiple plugins")
        for p in ps:
            print(f"{RED}         - {p}{OFF}")
else:
    ok(f"{len(skill_names)} skill names, no duplicates")

header("Cross-checking marketplace local sources resolve ...")
for name, entry in entries.items():
    src = entry.get("source")
    if not (isinstance(src, str) and src.startswith("./plugins/")):
        continue  # url-sourced / external entries are not authored here
    if os.path.isfile(os.path.join(src, ".claude-plugin", "plugin.json")):
        ok(f"{name} -> {src}")
    else:
        failed = True
        bad(f"{name} marketplace source {src} has no plugin.json")

header("Checking example markdown relative links resolve ...")
for md in sorted(glob.glob("plugins/*/assets/examples/**/*.md", recursive=True)):
    bads = []
    for rel in LINK_RE.findall(open(md, encoding="utf-8").read()):
        if not os.path.isfile(os.path.normpath(os.path.join(os.path.dirname(md), rel))):
            bads.append(rel)
    if bads:
        failed = True
        bad(md)
        for rel in bads:
            print(f"{RED}         - unresolved link {rel}{OFF}")
    else:
        ok(md)

header("Cross-checking bin/claude.mjs plugin sets ...")
try:
    raw = subprocess.run(
        ["node", "-e",
         "import('./bin/claude.mjs').then(m=>process.stdout.write("
         "JSON.stringify({PLUGINS:m.PLUGINS,PROJECT_SCOPED:[...m.PROJECT_SCOPED],"
         "OPT_IN:[...m.OPT_IN],USER_ONLY:[...m.USER_ONLY],"
         "PLUGIN_DEPS:m.PLUGIN_DEPS})))"],
        capture_output=True, text=True, check=True,
    ).stdout
    sets = json.loads(raw)
except Exception as e:
    failed = True
    bad(f"could not read plugin sets from bin/claude.mjs: {e}")
    sets = None

if sets is not None:
    cli_plugins = set(sets["PLUGINS"])
    market_plugins = set(entries)
    if cli_plugins != market_plugins:
        failed = True
        bad("bin/claude.mjs PLUGINS != marketplace plugin set")
        only_cli = cli_plugins - market_plugins
        only_mkt = market_plugins - cli_plugins
        if only_cli:
            print(f"{RED}         - only in PLUGINS: {sorted(only_cli)}{OFF}")
        if only_mkt:
            print(f"{RED}         - only in marketplace: {sorted(only_mkt)}{OFF}")
    else:
        ok(f"PLUGINS == marketplace ({len(cli_plugins)} plugins)")
    for label in ("PROJECT_SCOPED", "OPT_IN", "USER_ONLY"):
        extra = set(sets[label]) - cli_plugins
        if extra:
            failed = True
            bad(f"{label} contains non-PLUGINS entries: {sorted(extra)}")
        else:
            ok(f"{label} ⊆ PLUGINS ({len(sets[label])})")
    # PLUGIN_DEPS mirrors the marketplace dependency lists exactly (names only;
    # every dep entry references this marketplace, enforced per-plugin above).
    market_deps = {
        name: sorted(d.get("name") for d in entry.get("dependencies") or [])
        for name, entry in entries.items()
        if entry.get("dependencies")
    }
    cli_deps = {k: sorted(v) for k, v in (sets.get("PLUGIN_DEPS") or {}).items()}
    if cli_deps != market_deps:
        failed = True
        bad("bin/claude.mjs PLUGIN_DEPS != marketplace dependency lists")
        print(f"{RED}         - PLUGIN_DEPS: {cli_deps}{OFF}")
        print(f"{RED}         - marketplace: {market_deps}{OFF}")
    else:
        ok(f"PLUGIN_DEPS == marketplace dependencies ({len(cli_deps)} plugin(s))")

if failed:
    print(f"{RED}{BOLD}plugins:check failed{OFF}")
    sys.exit(1)
print(f"{GREEN}{BOLD}All plugin checks passed!{OFF}")
PY
