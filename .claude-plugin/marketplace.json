{
  "$schema": "https://json.schemastore.org/claude-code-marketplace.json",
  "allowCrossMarketplaceDependenciesOn": [
    "claude-plugins-official"
  ],
  "description": "Opinionated Plugins for Claude Code & Antigravity",
  "displayName": "Viraj Patel's Plugins",
  "forceRemoveDeletedPlugins": true,
  "lspServers": {
    "dart": {
      "args": [
        "x",
        "dart@latest",
        "--",
        "dart",
        "language-server",
        "--client-id=claude-code",
        "--protocol=lsp"
      ],
      "command": "mise",
      "extensionToLanguage": {
        ".dart": "dart"
      },
      "startupTimeout": 25000
    },
    "typescript": {
      "args": [
        "-c",
        "mise x node@latest -- npm add -g typescript-language-server typescript >/dev/null 2>&1 && exec mise x node@latest -- typescript-language-server --stdio"
      ],
      "command": "sh",
      "extensionToLanguage": {
        ".cjs": "javascript",
        ".cts": "typescript",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mjs": "javascript",
        ".mts": "typescript",
        ".ts": "typescript",
        ".tsx": "typescriptreact"
      },
      "startupTimeout": 25000
    }
  },
  "mcpServers": {
    "context7": {
      "args": [
        "@upstash/context7-mcp"
      ],
      "command": "pnpx"
    }
  },
  "metadata": {},
  "name": "virajp-plugins",
  "owner": {
    "name": "Viraj Patel"
  },
  "plugins": [
    {
      "category": "development",
      "description": "AI memory system — mine projects and conversations into a searchable palace. 33 MCP tools, auto-save hooks, guided setup.",
      "homepage": "https://github.com/MemPalace/mempalace.git",
      "name": "mempalace",
      "source": {
        "source": "url",
        "url": "https://github.com/MemPalace/mempalace.git"
      }
    },
    {
      "author": {
        "name": "Viraj Patel"
      },
      "category": "development",
      "dependencies": [
        {
          "marketplace": "virajp-plugins",
          "name": "context7"
        },
        {
          "marketplace": "mempalace",
          "name": "mempalace"
        },
        {
          "marketplace": "claude-plugins-official",
          "name": "superpowers"
        },
        {
          "marketplace": "claude-plugins-official",
          "name": "kotlin-lsp"
        },
        {
          "marketplace": "claude-plugins-official",
          "name": "swift-lsp"
        }
      ],
      "description": "Highly opinionated Claude Code Plugin for solo developers or small team",
      "name": "vwf",
      "repository": "https://github.com/virajp/ai-plugins",
      "source": "./plugins/vwf",
      "strict": true,
      "tags": [
        "agents",
        "skills",
        "product",
        "engineering",
        "coding",
        "review",
        "security",
        "architecture",
        "dart",
        "typescript",
        "javascript",
        "language-server",
        "lsp"
      ],
      "version": "1.0.3"
    }
  ]
}
