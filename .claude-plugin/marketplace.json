{
  "$schema": "https://json.schemastore.org/claude-code-marketplace.json",
  "allowCrossMarketplaceDependenciesOn": [],
  "description": "Opinionated Plugins for Claude Code & Antigravity",
  "displayName": "vPlugins",
  "forceRemoveDeletedPlugins": true,
  "metadata": {},
  "name": "vplugins",
  "owner": {
    "name": "Viraj Patel"
  },
  "plugins": [
    {
      "author": {
        "name": "Viraj Patel"
      },
      "category": "development",
      "description": "TypeScript/JavaScript language server",
      "lspServers": {
        "typescript": {
          "args": [
            "-c",
            "mise x node@latest -- npm add -g typescript-language-server typescript >/dev/null 2>&1 && exec mise x node@latest -- typescript-language-server --stdio"
          ],
          "command": "sh",
          "extensionToLanguage": {
            ".cjs": "javascript",
            ".cts": "typescript",
            ".js": "javascript",
            ".jsx": "javascriptreact",
            ".mjs": "javascript",
            ".mts": "typescript",
            ".ts": "typescript",
            ".tsx": "typescriptreact"
          },
          "startupTimeout": 60000
        }
      },
      "name": "vlsp-ts-js",
      "source": "./",
      "strict": false,
      "tags": [
        "typescript",
        "javascript",
        "language-server",
        "lsp"
      ],
      "version": "1.0.3"
    },
    {
      "author": {
        "name": "Viraj Patel"
      },
      "category": "development",
      "description": "Dart language server",
      "lspServers": {
        "dart": {
          "args": [
            "x",
            "dart@latest",
            "--",
            "dart",
            "language-server",
            "--client-id=claude-code",
            "--protocol=lsp"
          ],
          "command": "mise",
          "extensionToLanguage": {
            ".dart": "dart"
          },
          "startupTimeout": 60000
        }
      },
      "name": "vlsp-dart",
      "source": "./",
      "strict": false,
      "tags": [
        "dart",
        "language-server",
        "lsp"
      ],
      "version": "1.0.0"
    },
    {
      "name": "vskills",
      "skills": [
        "./skills/"
      ],
      "source": "./",
      "tags": [
        "skills"
      ],
      "version": "1.0.0"
    }
  ]
}