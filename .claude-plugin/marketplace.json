{
  "$schema": "https://json.schemastore.org/claude-code-marketplace.json",
  "description": "Opinionated Claude Code plugins",
  "name": "virajp-claude-plugins",
  "owner": {
    "name": "Viraj Patel"
  },
  "plugins": [
    {
      "author": {
        "name": "Viraj Patel"
      },
      "category": "development",
      "description": "TypeScript/JavaScript language server",
      "lspServers": {
        "typescript": {
          "args": [
            "x",
            "pnpm@latest",
            "--",
            "pnpm",
            "dlx",
            "--package",
            "typescript-language-server",
            "--package",
            "typescript",
            "typescript-language-server",
            "--stdio"
          ],
          "command": "mise",
          "extensionToLanguage": {
            ".cjs": "javascript",
            ".cts": "typescript",
            ".js": "javascript",
            ".jsx": "javascriptreact",
            ".mjs": "javascript",
            ".mts": "typescript",
            ".ts": "typescript",
            ".tsx": "typescriptreact"
          },
          "startupTimeout": 60000
        }
      },
      "name": "ts-js-lsp",
      "source": "./",
      "strict": false,
      "version": "1.0.1"
    },
    {
      "author": {
        "name": "Viraj Patel"
      },
      "category": "development",
      "description": "Dart language server",
      "lspServers": {
        "dart": {
          "args": [
            "x",
            "dart@latest",
            "--",
            "dart",
            "language-server",
            "--client-id=claude-code",
            "--protocol=lsp"
          ],
          "command": "mise",
          "extensionToLanguage": {
            ".dart": "dart"
          },
          "startupTimeout": 60000
        }
      },
      "name": "dart-lsp",
      "source": "./",
      "strict": false,
      "version": "1.0.0"
    }
  ]
}