{
  "name": "@askviraj/ai-plugins",
  "version": "1.0.0",
  "description": "CLI to install Viraj Patel's powerline statusline into Claude Code (~/.claude/settings.json)",
  "license": "MIT",
  "author": "Viraj Patel",
  "repository": "github:virajp/ai-plugins",
  "type": "commonjs",
  "bin": {
    "ai-plugins": "./bin/installer.js"
  },
  "files": [
    "bin",
    "tools"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@oclif/core": "^4"
  },
  "oclif": {
    "bin": "ai-plugins",
    "commands": {
      "strategy": "single",
      "target": "./bin/installer.js"
    }
  }
}
