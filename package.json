{
  "name": "@askviraj/ai-plugins",
  "version": "1.2.10",
  "description": "CLI to install Viraj Patel's Claude Code toolkit: marketplace plugins (via the claude CLI) and the powerline statusline",
  "keywords": [
    "claude",
    "claude-code",
    "claude-code-plugin",
    "claude-code-plugins",
    "marketplace",
    "statusline",
    "powerline",
    "subagent",
    "cli",
    "mcp",
    "lsp",
    "vwf",
    "context7",
    "mempalace",
    "ai",
    "anthropic",
    "oclif"
  ],
  "repository": "github:virajp/ai-plugins",
  "license": "MIT",
  "author": "Viraj Patel",
  "type": "commonjs",
  "bin": {
    "ai-plugins": "./bin/installer.js"
  },
  "files": [
    "bin",
    "tools"
  ],
  "oclif": {
    "bin": "ai-plugins",
    "commands": {
      "strategy": "single",
      "target": "./bin/installer.js"
    }
  },
  "dependencies": {
    "@oclif/core": "4.11.8"
  },
  "engines": {
    "node": ">=18"
  }
}
