{
  "$schema": "https://www.schemastore.org/claude-code-plugin-manifest.json",
  "agents": "./agents/*.md",
  "commands": "./commands",
  "hooks": "./hooks/hooks.json",
  "lspServers": {
    "dart": {
      "args": [
        "x",
        "dart@latest",
        "--",
        "dart",
        "language-server",
        "--client-id=claude-code",
        "--protocol=lsp"
      ],
      "command": "mise",
      "extensionToLanguage": {
        ".dart": "dart"
      },
      "startupTimeout": 25000
    },
    "typescript": {
      "args": [
        "-c",
        "mise x node@latest -- npm add -g typescript-language-server typescript >/dev/null 2>&1 && exec mise x node@latest -- typescript-language-server --stdio"
      ],
      "command": "sh",
      "extensionToLanguage": {
        ".cjs": "javascript",
        ".cts": "typescript",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mjs": "javascript",
        ".mts": "typescript",
        ".ts": "typescript",
        ".tsx": "typescriptreact"
      },
      "startupTimeout": 25000
    }
  },
  "mcpServers": {
    "context7": {
      "args": [
        "@upstash/context7-mcp"
      ],
      "command": "pnpx"
    }
  },
  "name": "vwf",
  "settings": {
    "statusLine": {
      "command": "pnpm dlx ccstatusline",
      "padding": 0,
      "refreshInterval": 4,
      "type": "command"
    }
  }
}
