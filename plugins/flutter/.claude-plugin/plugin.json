{
  "$schema": "https://www.schemastore.org/claude-code-plugin-manifest.json",
  "name": "flutter",
  "lspServers": {
    "dart": {
      "args": [
        "x",
        "dart@latest",
        "--",
        "dart",
        "language-server",
        "--client-id=claude-code",
        "--protocol=lsp"
      ],
      "command": "mise",
      "extensionToLanguage": {
        ".dart": "dart"
      },
      "startupTimeout": 60000
    }
  },
  "dependencies": [
    {
      "marketplace": "claude-plugins-official",
      "name": "swift-lsp"
    },
    {
      "marketplace": "claude-plugins-official",
      "name": "kotlin-lsp"
    }
  ]
}
