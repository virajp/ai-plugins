{
  "$schema": "https://www.schemastore.org/claude-code-plugin-manifest.json",
  "name": "flutter",
  "lspServers": {
    "dart": {
      "args": [
        "x",
        "dart@latest",
        "--",
        "dart",
        "language-server",
        "--client-id=claude-code",
        "--protocol=lsp"
      ],
      "command": "mise",
      "extensionToLanguage": {
        ".dart": "dart"
      },
      "startupTimeout": 60000
    },
    "kotlin-lsp": {
      "args": [
        "--stdio"
      ],
      "command": "kotlin-lsp",
      "extensionToLanguage": {
        ".kt": "kotlin",
        ".kts": "kotlin"
      },
      "startupTimeout": 120000
    },
    "sourcekit-lsp": {
      "command": "sourcekit-lsp",
      "extensionToLanguage": {
        ".swift": "swift"
      }
    }
  }
}
