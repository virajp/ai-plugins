#!/usr/bin/env bash
#MISE description="Bootstrap the project: toolchain, dependencies, pre-commit"
#MISE depends=["init"]

#USAGE flag "--clean" help="Recreate the virtualenv from scratch"

set -e
source "${MISE_PROJECT_ROOT}/.config/mise/tasks/_scripts/_helpers"

line_sep "="
mise run setup:mise

if [[ "${usage_clean:-false}" == "true" ]]; then
  line_sep "="
  print_header "Removing .venv ..."
  rm -rf .venv || true
fi

line_sep "="
mise run setup:uv:sync

line_sep "="
mise run setup:uv:outdated

line_sep "="
mise run setup:precommit

line_sep "="
print_header "Setup complete!"
