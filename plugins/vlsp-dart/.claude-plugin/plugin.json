{
  "$schema": "https://www.schemastore.org/claude-code-plugin-manifest.json",
  "lspServers": {
    "dart": {
      "args": [
        "x",
        "dart@latest",
        "--",
        "dart",
        "language-server",
        "--client-id=claude-code",
        "--protocol=lsp"
      ],
      "command": "mise",
      "extensionToLanguage": {
        ".dart": "dart"
      },
      "startupTimeout": 60000
    }
  },
  "name": "vlsp-dart"
}